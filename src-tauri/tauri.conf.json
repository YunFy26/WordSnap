{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WordSnap",
  "version": "0.1.1",
  "identifier": "com.yuntsy.wordsnap",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "float",
        "title": "WordSnap",
        "url": "index.html?view=float",
        "width": 300,
        "height": 118,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true,
        "windowEffects": {
          "effects": ["popover"],
          "state": "active",
          "radius": 13
        }
      },
      {
        "label": "words",
        "title": "词表",
        "url": "index.html?view=words",
        "width": 396,
        "height": 420,
        "minWidth": 360,
        "minHeight": 300,
        "visible": false,
        "resizable": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "windowEffects": {
          "effects": ["popover"],
          "state": "active",
          "radius": 12
        }
      },
      {
        "label": "settings",
        "title": "设置",
        "url": "index.html?view=settings",
        "width": 380,
        "height": 430,
        "minWidth": 360,
        "minHeight": 360,
        "visible": false,
        "resizable": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "windowEffects": {
          "effects": ["popover"],
          "state": "active",
          "radius": 12
        }
      },
      {
        "label": "menu",
        "title": "WordSnap",
        "url": "index.html?view=menu",
        "width": 228,
        "height": 166,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true,
        "windowEffects": {
          "effects": ["menu", "blur"],
          "state": "active",
          "radius": 9
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
